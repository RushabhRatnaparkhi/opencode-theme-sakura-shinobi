{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "violet900": "#160a24",
    "violet850": "#1d0f2f",
    "violet800": "#24143a",
    "violet750": "#2d1a47",
    "violet700": "#372056",
    "violet650": "#44296a",
    "violet600": "#563587",
    "violet500": "#7449b5",
    "pink700": "#b53c8a",
    "pink600": "#cc4f9a",
    "pink500": "#e05cab",
    "pink400": "#ef78bf",
    "rose500": "#f072b0",
    "blue500": "#58a6ff",
    "green500": "#6edb8f",
    "amber500": "#ffbf66",
    "red500": "#ff6f91",
    "textMain": "#f6efff",
    "textMuted": "#cbb7e6",
    "textDim": "#9a86b9",
    "lightBg": "#fff6fd",
    "lightPanel": "#ffeefe",
    "lightElement": "#f4dcff",
    "lightText": "#3b154f",
    "lightMuted": "#744a90"
  },
  "theme": {
    "primary": {
      "dark": "pink500",
      "light": "pink700"
    },
    "secondary": {
      "dark": "violet500",
      "light": "violet600"
    },
    "accent": {
      "dark": "pink400",
      "light": "rose500"
    },
    "error": {
      "dark": "red500",
      "light": "red500"
    },
    "warning": {
      "dark": "amber500",
      "light": "amber500"
    },
    "success": {
      "dark": "green500",
      "light": "green500"
    },
    "info": {
      "dark": "blue500",
      "light": "blue500"
    },
    "text": {
      "dark": "textMain",
      "light": "lightText"
    },
    "textMuted": {
      "dark": "textMuted",
      "light": "lightMuted"
    },
    "background": {
      "dark": "violet900",
      "light": "lightBg"
    },
    "backgroundPanel": {
      "dark": "violet850",
      "light": "lightPanel"
    },
    "backgroundElement": {
      "dark": "violet800",
      "light": "lightElement"
    },
    "border": {
      "dark": "violet650",
      "light": "#d9b2f6"
