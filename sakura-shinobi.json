    "markdownCodeBlock": {
      "dark": "textMuted",
      "light": "lightText"
    },
    "syntaxComment": {
      "dark": "textDim",
      "light": "#8d70a7"
    },
    "syntaxKeyword": {
      "dark": "pink500",
      "light": "pink700"
    },
    "syntaxFunction": {
      "dark": "#bc9cff",
      "light": "violet600"
    },
    "syntaxVariable": {
      "dark": "#f7b5db",
      "light": "#a63f7f"
    },
    "syntaxString": {
      "dark": "#8decae",
      "light": "#197748"
    },
    "syntaxNumber": {
      "dark": "#ffc786",
      "light": "#9b5d00"
    },
    "syntaxType": {
      "dark": "#8bc2ff",
      "light": "#245cb0"
    },
    "syntaxOperator": {
      "dark": "pink400",
      "light": "pink700"
    },
    "syntaxPunctuation": {
      "dark": "textMain",
      "light": "lightText"
    }
