    "markdownHeading": {
      "dark": "pink400",
      "light": "pink700"
    },
    "markdownLink": {
      "dark": "blue500",
      "light": "#2e73d4"
    },
    "markdownLinkText": {
      "dark": "#88c7ff",
      "light": "#2258a6"
    },
    "markdownCode": {
      "dark": "#f5a7d2",
      "light": "#9a2e70"
    },
    "markdownBlockQuote": {
      "dark": "textDim",
      "light": "#8762a4"
    },
    "markdownEmph": {
      "dark": "amber500",
      "light": "#a56a00"
    },
    "markdownStrong": {
      "dark": "pink500",
      "light": "pink700"
